SHELL=  /bin/sh
COMP=   ifort
FFLAGS= -O2 -check bounds -check format -xHost -fpe0

leadtime:      leadtime.f
	@echo " "
	@echo "  Compiling the TC genesis probability program....."
	$(COMP) $(FFLAGS) leadtime.f -o leadtime
	@echo " "

CMD = leadtime

clean:
	-rm -f  *.mod

install:
	mv $(CMD) ../../exec/$(CMD)
